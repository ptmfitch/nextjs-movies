{
  "version": 1,
  "hooks": {
    "beforeShellExecution": [
      {
        "command": "python3 .cursor/hooks/block-destructive-shell.py",
        "failClosed": true
      }
    ],
    "postToolUse": [
      {
        "command": "python3 .cursor/hooks/check-types.py",
        "matcher": "Write|StrReplace"
      }
    ]
  }
}
